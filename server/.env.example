# THE ONLY MIND — brain configuration (copy to server/.env and fill in)

# mock  = scripted interior, fully offline, free (default)
# live  = every cognition is a real LLM call
# hybrid = every 3rd cognition is live, the rest mock (cheap dry run)
BRAIN_MODE=live

# --- OpenAI ---
LLM_API_KEY=sk-...
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o
# pricing (USD per 1M tokens) for the daily budget breaker
LLM_PRICE_IN=2.5
LLM_PRICE_OUT=10

# --- or Anthropic (OpenAI-compatible endpoint) ---
# LLM_API_KEY=sk-ant-...
# LLM_BASE_URL=https://api.anthropic.com/v1
# LLM_MODEL=claude-sonnet-5
# LLM_PRICE_IN=3
# LLM_PRICE_OUT=15

# hard daily spend cap in USD — past this the mind degrades to mock until
# the next UTC day (never a surprise bill)
LLM_DAILY_USD=10

# ADMIN_PASSWORD=...   (slice 11)
# DB_PATH=/data/onlymind.db   (prod volume; defaults to server/onlymind.db in dev)

# the inscription the mind carries but cannot rephrase — set to the real
# contract address when it exists; "placeholder" (or unset) disables it
CA=placeholder
