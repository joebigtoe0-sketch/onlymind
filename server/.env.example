# THE ONLY MIND — brain configuration (copy to server/.env and fill in)

# mock  = scripted interior, fully offline, free (default)
# live  = every cognition is a real LLM call
# hybrid = every 3rd cognition is live, the rest mock (cheap dry run)
BRAIN_MODE=live

# --- OpenAI ---
LLM_API_KEY=sk-...
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o
# pricing (USD per 1M tokens) for the daily budget breaker
LLM_PRICE_IN=2.5
LLM_PRICE_OUT=10

# --- or Anthropic (OpenAI-compatible endpoint) ---
# LLM_API_KEY=sk-ant-...
# LLM_BASE_URL=https://api.anthropic.com/v1
# LLM_MODEL=claude-sonnet-5
# LLM_PRICE_IN=3
# LLM_PRICE_OUT=15

# hard daily spend cap in USD — past this the mind degrades to mock until
# the next UTC day (never a surprise bill)
LLM_DAILY_USD=10

# per-role models: the whole-mind voice (and meditations) deserve the
# strongest model you can afford; fragments/dwellers can stay cheap
# LLM_MODEL_MIND=gpt-4.1
# LLM_MODEL_FRAGMENT=gpt-4o-mini

# ADMIN_PASSWORD=...   (slice 11)
# DB_PATH=/data/onlymind.db   (prod volume; defaults to server/onlymind.db in dev)

# the inscription the mind carries but cannot rephrase — set to the real
# contract address when it exists; "placeholder" (or unset) disables it.
# When CHAIN is on, this is also the mint the mind watches and trades.
CA=placeholder

# ---- the chain (pump.fun / Solana) ----
# off = no chain at all; dry = full fiction, records everything, signs nothing;
# live = real transactions (needs CA + HELIUS_APIKEY + WALLET_SECRET)
CHAIN=off
HELIUS_APIKEY=
# base58 secret key of the mind's wallet (the marrow holder). NEVER commit.
WALLET_SECRET=
# guardrails: it never sells. Buys are FUNDED BY CLAIMED FEES — it may spend
# up to CHAIN_BUYBACK_RATIO of everything ever claimed, 0.01-1 SOL at a time.
# Fees are claimed whenever >= CHAIN_CLAIM_MIN_SOL waits in the vault (checked
# every 10 min), or after the fallback interval regardless. Burns roll a
# random 0..CHAIN_BURN_MAX_PCT of holdings per world-death.
CHAIN_BUY_MIN=0.01
CHAIN_BUY_MAX=1
CHAIN_BUYBACK_RATIO=0.6
CHAIN_BUY_COOLDOWN_MIN=10
CHAIN_DAILY_SOL=10
CHAIN_BURN_MAX_PCT=30
CHAIN_BURN_COOLDOWN_MIN=45
CHAIN_CLAIM_MIN_SOL=1
CHAIN_CLAIM_FALLBACK_H=24
CHAIN_WHALE_BUY_SOL=1
CHAIN_WHALE_SELL_SOL=1.5
